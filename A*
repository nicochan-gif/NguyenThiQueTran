 import math

class DeliveryGraph:
    def __init__(self, graph, coordinates):
        self.graph = graph
        self.coordinates = coordinates

    # Lấy hàng xóm
    def get_neighbors(self, node):
        return self.graph[node]

    # Heuristic: khoảng cách Euclid
    def h(self, n, goal):
        x1, y1 = self.coordinates[n]
        x2, y2 = self.coordinates[goal]
        return math.sqrt((x1 - x2)**2 + (y1 - y2)**2)

    # Thuật toán A*
    def a_star(self, start, goal):
        open_set = set([start])
        closed_set = set()

        g = {start: 0}
        parent = {start: start}

        while open_set:
            # chọn node tốt nhất
            n = min(open_set, key=lambda x: g[x] + self.h(x, goal))

            # nếu tới đích
            if n == goal:
                path = []
                while parent[n] != n:
                    path.append(n)
                    n = parent[n]
                path.append(start)
                path.reverse()

                print("Đường giao hàng tối ưu:", path)
                print("Tổng chi phí:", g[goal])
                return path

            # duyệt hàng xóm
            for (m, weight) in self.get_neighbors(n):
                if m not in open_set and m not in closed_set:
                    open_set.add(m)
                    parent[m] = n
                    g[m] = g[n] + weight
                else:
                    if g[m] > g[n] + weight:
                        g[m] = g[n] + weight
                        parent[m] = n
                        if m in closed_set:
                            closed_set.remove(m)
                            open_set.add(m)

            open_set.remove(n)
            closed_set.add(n)

        print("Không tìm được đường giao hàng")
        return None


