#Bài 1. Cài đặt lại thuật toán k-means.
import numpy as np

def kmeans(X, k, max_iter=100):
    # khởi tạo tâm cụm
    centers = X[np.random.choice(len(X), k, replace=False)]

    for _ in range(max_iter):
        # tính khoảng cách
        distances = np.linalg.norm(X[:, np.newaxis] - centers, axis=2)
        labels = np.argmin(distances, axis=1)

        # cập nhật tâm
        new_centers = np.array([X[labels == i].mean(axis=0) for i in range(k)])

        # kiểm tra hội tụ
        if np.allclose(centers, new_centers):
            break

        centers = new_centers

    return centers, labels

#Bài 2. Cài đặt lại thuật toán k-NN với 2 cách đánh giá trọng số k.
def knn_weighted(X_train, y_train, X_test, k):
    predictions = []

    for test in X_test:
        distances = np.linalg.norm(X_train - test, axis=1)
        idx = np.argsort(distances)[:k]

        weights = {}
        for i in idx:
            label = y_train[i]
            w = 1 / (distances[i] + 1e-5)  # tránh chia 0
            weights[label] = weights.get(label, 0) + w

        predictions.append(max(weights, key=weights.get))

    return np.array(predictions)

#Bài 3. Cài đặt ứng dụng demo cho 2 thuật toán trên.
import matplotlib.pyplot as plt
import numpy as np

# Hàm KNN cơ bản
def knn_basic(X_train, y_train, X_test, k):
    predictions = []
    for test_point in X_test:
        # Tính khoảng cách Euclidean đến tất cả các điểm huấn luyện
        distances = np.linalg.norm(X_train - test_point, axis=1)
        
        # Lấy chỉ mục của k điểm gần nhất
        k_nearest_indices = np.argsort(distances)[:k]
        
        # Lấy nhãn của k điểm gần nhất
        k_nearest_labels = y_train[k_nearest_indices]
        
        # Thực hiện bỏ phiếu đa số để dự đoán nhãn
        unique_labels, counts = np.unique(k_nearest_labels, return_counts=True)
        predicted_label = unique_labels[np.argmax(counts)]
        predictions.append(predicted_label)
    return np.array(predictions)

# tạo dữ liệu
np.random.seed(0)
X = np.random.rand(100, 2)

# KMeans demo
centers, labels = kmeans(X, 3)

plt.scatter(X[:,0], X[:,1], c=labels)
plt.scatter(centers[:,0], centers[:,1], c='red', s=200)
plt.title("K-Means Demo")
plt.show()


# KNN demo
y = np.random.randint(0, 2, 100)

X_test = np.array([[0.5, 0.5]])

print("KNN basic:", knn_basic(X, y, X_test, 5))
print("KNN weighted:", knn_weighted(X, y, X_test, 5))

