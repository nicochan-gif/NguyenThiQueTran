import pandas as pd
import matplotlib.pyplot as plt

def cau5():
    # Tao du lieu
    data = {
        "Ten": ["An", "Binh", "Chi"],
        "Diem": [8.5, 7.8, 9.0]
    }

    # Tao DataFrame
    df = pd.DataFrame(data)

    print("Bang du lieu:")
    print(df)

    # Luu ra file CSV
    df.to_csv("sinhvien.csv", index=False)
    print("\nDa luu file sinhvien.csv")

    # Doc lai file CSV
    df2 = pd.read_csv("sinhvien.csv")
    print("\nDoc lai tu file:")
    print(df2)

    # Ve bieu do
    plt.plot(df["Ten"], df["Diem"], marker='o')
    plt.title("Diem sinh vien")
    plt.xlabel("Ten")
    plt.ylabel("Diem")

    plt.show()

# chạy
cau5()
