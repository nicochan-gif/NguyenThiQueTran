def tron_mang(a, b):
    c = []
    n = min(len(a), len(b))
    
    # Lấy min từng cặp
    for i in range(n):
        c.append(min(a[i], b[i]))
    
    # Thêm phần dư
    if len(a) > len(b):
        c.extend(a[n:])
    else:
        c.extend(b[n:])
    
    return c

